{
  "name": "@priceline/storybook",
  "version": "1.0.0",
  "description": "Storybook for pcln-design-system",
  "license": "MIT",
  "author": "Priceline Design System Working Group",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "",
    "start": "storybook dev -p 6767",
    "storybook": "run-s storybook:build chromatic",
    "storybook:baseline": "run-s storybook:build storybook:baseline:chromatic",
    "storybook:build": "storybook build --stats-json --output-dir=../docs/out/storybook",
    "storybook:baseline:chromatic": "chromatic --storybook-build-dir=../docs/out/storybook --auto-accept-changes --exit-once-uploaded",
    "chromatic": "chromatic --storybook-build-dir=../docs/out/storybook --exit-once-uploaded --only-changed --trace-changed --untraced=**/package.json",
    "storybook:coverage": "test-storybook --coverage"
  },
  "devDependencies": {
    "@priceline/eslint-config": "workspace:*",
    "@rushstack/eslint-patch": "^1.15.0",
    "@storybook/addon-a11y": "10.2.0-alpha.14",
    "@storybook/addon-docs": "10.2.0-alpha.14",
    "@storybook/addon-mcp": "^0.1.8",
    "@storybook/react-vite": "10.2.0-alpha.14",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "chromatic": "^13.3.4",
    "eslint": "^8.55.0",
    "eslint-plugin-storybook": "10.2.0-alpha.14",
    "npm-run-all": "^4.1.5",
    "pcln-design-system": "workspace:*",
    "pcln-icons": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "require-from-string": "2.0.2",
    "storybook": "10.2.0-alpha.14",
    "styled-components": "^5.3.11",
    "typescript": "^5.3.3",
    "vite": "^7.2.7"
  }
}
